{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.web3forms.com https://vitals.vercel-insights.com https://va.vercel-scripts.com https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com; frame-src https://www.google.com https://maps.google.com; frame-ancestors 'none'; form-action 'self' https://api.web3forms.com; base-uri 'self'; upgrade-insecure-requests;"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/que-es", "destination": "/quienes-somos", "permanent": true },
    { "source": "/para-ti", "destination": "/domotica/hogares", "permanent": true },
    { "source": "/para-empresas", "destination": "/domotica/empresas", "permanent": true },
    { "source": "/nuestro-proceso", "destination": "/domotica", "permanent": true },
    { "source": "/domotica-para-hogares-es.html", "destination": "/domotica/hogares", "permanent": true },
    { "source": "/domotica-para-empresas-es.html", "destination": "/domotica/empresas", "permanent": true },
    { "source": "/domotica-asistencial-es.html", "destination": "/domotica", "permanent": true },
    { "source": "/instalacion-domotica-es.html", "destination": "/domotica", "permanent": true },
    { "source": "/blog-es.html", "destination": "/recursos", "permanent": true },
    { "source": "/contacto-es.html", "destination": "/contacto", "permanent": true },
    { "source": "/index-en.html", "destination": "/", "permanent": true },
    { "source": "/index-ca.html", "destination": "/ca", "permanent": true },
    { "source": "/blog/knx-vs-home-assistant", "destination": "/blog/home-assistant", "permanent": true },
    { "source": "/ca/blog/knx-vs-home-assistant", "destination": "/ca/blog/home-assistant", "permanent": true }
  ]
}
