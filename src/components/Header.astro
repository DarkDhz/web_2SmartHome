---
const pathname = Astro.url.pathname;
const isCA = pathname.startsWith('/ca');
const prefix = isCA ? '/ca' : '';

const rawPath = isCA ? (pathname.replace(/^\/ca/, '') || '/') : pathname;
const esUrl = rawPath;
const caUrl = rawPath === '/' ? '/ca' : `/ca${rawPath}`;

const isActive = (path: string) => {
  if (path === '/') return pathname === '/' || pathname === '/ca' || pathname === '/ca/';
  return pathname.startsWith(`${prefix}${path}`);
};

const t = isCA ? {
  domotica: 'Domòtica',
  hogares: 'Llars',
  hogaresSub: 'Automatització residencial',
  empresas: 'Empreses',
  empresasSub: 'Edificis i oficines',
  soluciones: 'Solucions',
  proyectos: 'Projectes',
  quienesSomos: 'Qui som',
  recursos: 'Recursos',
  presupuesto: 'Demanar pressupost',
  presupuestoMobile: 'Pressupost gratis',
  domoticaHogares: 'Domòtica llars',
  domoticaEmpresas: 'Domòtica empreses',
  sobreName: 'Sobre 2SmartHome',
  recursosUtil: 'Recursos útils',
  contacteDirect: 'Contacte directe',
  contacte: 'Contacte',
  abrirMenu: 'Obrir menú',
} : {
  domotica: 'Domótica',
  hogares: 'Hogares',
  hogaresSub: 'Automatización residencial',
  empresas: 'Empresas',
  empresasSub: 'Edificios y oficinas',
  soluciones: 'Soluciones',
  proyectos: 'Proyectos',
  quienesSomos: 'Quiénes somos',
  recursos: 'Recursos',
  presupuesto: 'Pedir presupuesto',
  presupuestoMobile: 'Presupuesto gratis',
  domoticaHogares: 'Domótica hogares',
  domoticaEmpresas: 'Domótica empresas',
  sobreName: 'Sobre 2SmartHome',
  recursosUtil: 'Recursos útiles',
  contacteDirect: 'Contacto directo',
  contacte: 'Contacto',
  abrirMenu: 'Abrir menú',
};
---

<header class="fixed top-0 left-0 right-0 z-50 bg-slate-900/95 backdrop-blur-md border-b border-slate-800/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href={isCA ? '/ca' : '/'} class="flex items-center group flex-shrink-0" aria-label="2SmartHome">
        <img src="/img/logo-navbar.png" alt="2SmartHome" class="h-12 w-32 sm:w-36 object-contain transition-opacity duration-200 group-hover:opacity-90" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">

        <!-- Domòtica/Domótica dropdown -->
        <div class="relative group/dom">
          <a
            href={`${prefix}/domotica`}
            class={`flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${isActive('/domotica') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-800'}`}
          >
            {t.domotica}
            <svg class="w-4 h-4 transition-transform duration-200 group-hover/dom:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/dom:opacity-100 group-hover/dom:visible transition-all duration-200">
            <div class="w-56 bg-slate-800 border border-slate-700 rounded-xl shadow-2xl shadow-black/40 overflow-hidden">
              <a href={`${prefix}/domotica/hogares`} class={`flex items-center gap-3 px-4 py-3 text-sm transition-colors ${isActive('/domotica/hogares') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-700'}`}>
                <svg class="w-5 h-5 text-sky-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                <div>
                  <div class="font-medium">{t.hogares}</div>
                  <div class="text-xs text-slate-500">{t.hogaresSub}</div>
                </div>
              </a>
              <div class="h-px bg-slate-700"></div>
              <a href={`${prefix}/domotica/empresas`} class={`flex items-center gap-3 px-4 py-3 text-sm transition-colors ${isActive('/domotica/empresas') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-700'}`}>
                <svg class="w-5 h-5 text-sky-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                <div>
                  <div class="font-medium">{t.empresas}</div>
                  <div class="text-xs text-slate-500">{t.empresasSub}</div>
                </div>
              </a>
            </div>
          </div>
        </div>

        <a href={`${prefix}/soluciones`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${isActive('/soluciones') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-800'}`}>{t.soluciones}</a>
        <a href={`${prefix}/proyectos`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${isActive('/proyectos') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-800'}`}>{t.proyectos}</a>
        <a href={`${prefix}/quienes-somos`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${isActive('/quienes-somos') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-800'}`}>{t.quienesSomos}</a>
        <a href={`${prefix}/recursos`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 ${isActive('/recursos') ? 'text-sky-400 bg-sky-500/10' : 'text-slate-300 hover:text-white hover:bg-slate-800'}`}>{t.recursos}</a>

        <!-- Language switcher -->
        <div class="ml-2 flex items-center gap-0.5 bg-slate-800 border border-slate-700 rounded-lg p-0.5 text-xs font-semibold">
          <a
            href={esUrl}
            class={`px-2.5 py-1.5 rounded-md transition-colors ${!isCA ? 'bg-sky-500 text-white' : 'text-slate-400 hover:text-white'}`}
            aria-label="Versión en español"
          >ES</a>
          <a
            href={caUrl}
            class={`px-2.5 py-1.5 rounded-md transition-colors ${isCA ? 'bg-sky-500 text-white' : 'text-slate-400 hover:text-white'}`}
            aria-label="Versió en català"
          >CA</a>
        </div>

        <a href={`${prefix}/contacto#formulario`} class="ml-2 px-5 py-2.5 bg-sky-500 hover:bg-sky-400 text-white text-sm font-semibold rounded-xl transition-colors duration-200 shadow-lg shadow-sky-500/20">
          {t.presupuesto}
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button id="mobile-toggle" class="lg:hidden p-2 text-slate-400 hover:text-white transition-colors rounded-lg hover:bg-slate-800" aria-label={t.abrirMenu}>
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-800 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      <div class="pb-2">
        <p class="px-3 py-1 text-xs font-semibold text-slate-500 uppercase tracking-wider">{t.domotica}</p>
        <a href={`${prefix}/domotica/hogares`} class="flex items-center gap-2 px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">
          <svg class="w-4 h-4 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          {t.domoticaHogares}
        </a>
        <a href={`${prefix}/domotica/empresas`} class="flex items-center gap-2 px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">
          <svg class="w-4 h-4 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          {t.domoticaEmpresas}
        </a>
      </div>
      <a href={`${prefix}/soluciones`} class="block px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">{t.soluciones}</a>
      <a href={`${prefix}/proyectos`} class="block px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">{t.proyectos}</a>
      <a href={`${prefix}/quienes-somos`} class="block px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">{t.sobreName}</a>
      <a href={`${prefix}/recursos`} class="block px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">{t.recursosUtil}</a>
      <a href={`${prefix}/contacto`} class="block px-3 py-2.5 text-slate-300 hover:text-white hover:bg-slate-800 rounded-lg transition-colors text-sm">{t.contacteDirect}</a>
      <!-- Language switcher mobile -->
      <div class="flex items-center gap-2 px-3 py-2">
        <span class="text-xs text-slate-500 uppercase tracking-wider">Idioma:</span>
        <a href={esUrl} class={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors ${!isCA ? 'bg-sky-500 text-white' : 'bg-slate-800 text-slate-400 hover:text-white border border-slate-700'}`}>ES</a>
        <a href={caUrl} class={`px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors ${isCA ? 'bg-sky-500 text-white' : 'bg-slate-800 text-slate-400 hover:text-white border border-slate-700'}`}>CA</a>
      </div>
      <div class="pt-2">
        <a href={`${prefix}/contacto#formulario`} class="block w-full text-center px-5 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-sky-500/20 text-sm">
          {t.presupuestoMobile}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const hidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !hidden);
    iconClose?.classList.toggle('hidden', !!hidden);
  });
</script>
