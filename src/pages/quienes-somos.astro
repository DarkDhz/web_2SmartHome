---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const imgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**', { eager: true });
const getImg = (src: string) => imgs[src.replace('/img/', '/src/assets/img/')]!.default;

const _msgQS = `Hola, me gustaría ponerme en contacto con vuestro equipo.
· Mi proyecto: [describe brevemente]
· Tipo de espacio: [hogar / empresa] · Superficie: [m²]
· Zona: [Barcelona / área metropolitana]`;
const urlEquipo = `/contacto?tipo=otro&mensaje=${encodeURIComponent(_msgQS)}#formulario`;

const SITE_URL = 'https://www.2smarthome.es';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Quiénes Somos', item: `${SITE_URL}/quienes-somos` },
  ],
};

const values = [
  { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', title: 'Calidad sin compromiso', desc: 'Solo trabajamos con fabricantes líderes: Shelly, Aqara, Sonoff, SmLight, Somfy, Ajax, etc.' },
  { icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z', title: 'Orientados al cliente', desc: 'Acompañamos a cada cliente desde el primer contacto hasta años después de la instalación.' },
  { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', title: 'Privacidad y seguridad', desc: 'Sistemas locales que no dependen de servidores externos. Tus datos permanecen en tu hogar.' },
  { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Eficiencia energética', desc: 'Cada instalación está diseñada para reducir el consumo y minimizar el impacto ambiental.' },
];

---

<Layout
  title="Quiénes Somos – 2SmartHome Barcelona"
  seoTitle="Quiénes Somos — Equipo de Domótica Barcelona"
  description="Conoce al equipo de 2SmartHome, empresa de domótica con más de 2 años de experiencia en Barcelona y área metropolitana. Ingenieros especializados en automatización residencial y empresarial."
  schemas={[breadcrumbSchema]}
>

  <!-- HERO -->
  <section class="relative py-36 overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImg('/img/photo-1522071820081-009f0129c71c.jpg')} alt="Equipo 2SmartHome" width={1920} quality={70} fetchpriority="high" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/90 via-slate-950/70 to-slate-950"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">El equipo</p>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white mb-6">Quiénes somos</h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto">
        Somos un equipo de ingenieros y técnicos apasionados por la tecnología y comprometidos con mejorar la vida de nuestros clientes.
      </p>
    </div>
  </section>

  <!-- STORY -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-up">
          <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Nuestra historia</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Nacidos en Barcelona para transformar hogares</h2>
          <div class="space-y-4 text-slate-400 leading-relaxed">
            <p>2SmartHome nació en Barcelona en 2024 con una misión clara: hacer que la tecnología de automatización del hogar fuera accesible y útil para cualquier persona, no solo para los más tecnológicos.</p>
            <p>En poco más de dos años hemos completado más de 100 instalaciones en hogares, oficinas, hoteles y espacios comerciales de Barcelona y el área metropolitana. Cada proyecto nos ha enseñado algo nuevo y nos ha permitido perfeccionar nuestra metodología.</p>
            <p>Nuestro objetivo no es solo instalar tecnología, sino acompañarte: entender cómo vives, cómo trabajas y cómo queremos que tu espacio te facilite la vida. Eso es lo que nos diferencia.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 items-start fade-up">
          <Image src={getImg('/img/photo-1600585154340-be6161a56a0c.jpg')} alt="Vivienda moderna preparada para automatización domótica" width={800} class="w-full h-52 object-cover rounded-2xl" loading="lazy" />
          <Image src={getImg('/img/photo-1556909114-f6e7ad7d3136.jpg')} alt="Cocina inteligente integrada en un hogar conectado" width={800} class="w-full h-52 object-cover rounded-2xl mt-8" loading="lazy" />
          <Image src={getImg('/img/photo-1565814329452-e1efa11c5b89.jpg')} alt="Espacio residencial con soluciones de confort automatizado" width={800} class="w-full h-52 object-cover rounded-2xl -mt-8" loading="lazy" />
          <Image src={getImg('/img/photo-1497366216548-37526070297c.jpg')} alt="Oficina con sistemas inteligentes de iluminación y climatización" width={800} class="w-full h-52 object-cover rounded-2xl" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-24 bg-slate-900 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-up">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Lo que nos guía</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">Nuestros valores</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((v, i) => (
          <div class="p-7 bg-slate-800/50 border border-slate-700 rounded-2xl fade-up" style={`transition-delay:${i*80}ms`}>
            <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center mb-5">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={v.icon}/>
              </svg>
            </div>
            <h3 class="text-white font-semibold mb-2">{v.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-950 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">¿Hablamos?</h2>
      <p class="text-slate-400 mb-8">Nos encantaría conocer tu proyecto y ayudarte a hacerlo realidad.</p>
      <a href={urlEquipo} rel="nofollow" class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
        Contactar con el equipo
      </a>
    </div>
  </section>

</Layout>
