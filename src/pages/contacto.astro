---
import Layout from '../layouts/Layout.astro';

const googleMapsUrl = 'https://www.google.es/maps/place/2SmartHome/@41.4506426,2.2458014,17z/data=!3m1!4b1!4m6!3m5!1s0xab2d40321309cb1d:0xbef6271c31a9e354!8m2!3d41.4506386!4d2.2483763!16s%2Fg%2F11yvvpdd3y';
---

<Layout
  title="Contacto – Presupuesto de Domótica en Barcelona"
  description="Solicita un presupuesto gratuito para tu proyecto de domótica en Barcelona y área metropolitana. Visita de diagnóstico sin compromiso. Respondemos en menos de 24 horas. Carrer de Francesc Layret, 70, Badalona."
>

  <!-- HERO -->
  <section class="py-32 bg-slate-900 border-b border-slate-800 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">Hablemos</p>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white mb-6">Contacto</h1>
      <p class="text-xl text-slate-300">Cuéntanos tu proyecto y recibirás una respuesta personalizada en menos de 24 horas.</p>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section id="formulario" class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

        <!-- Info column -->
        <div class="lg:col-span-2 space-y-10 fade-up">
          <div>
            <h2 class="text-2xl font-bold text-white mb-6">Estamos aquí para ayudarte</h2>
            <p class="text-slate-400 leading-relaxed">
              Ya sea que tengas una idea clara de lo que quieres o que aún estés explorando opciones, nuestro equipo te guiará en cada paso del proceso.
            </p>
          </div>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <div class="text-white font-semibold mb-1">Teléfono</div>
                <a href="tel:+34660877744" class="text-slate-400 hover:text-sky-400 transition-colors">+34 660 877 744</a>
                <div class="text-slate-500 text-xs mt-1">Lun–Vie 9:00–18:00</div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="text-white font-semibold mb-1">Email</div>
                <a href="mailto:info@2smarthome.es" class="text-slate-400 hover:text-sky-400 transition-colors">info@2smarthome.es</a>
                <div class="text-slate-500 text-xs mt-1">Respondemos en &lt;24h</div>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="text-white font-semibold mb-1">Oficina</div>
                <div class="text-slate-400 text-sm">Carrer de Francesc Layret, 70</div>
                <div class="text-slate-400 text-sm">08911 Badalona, Barcelona</div>
              </div>
            </div>
          </div>

          <!-- Quick benefits -->
          <div class="p-6 bg-slate-900 border border-slate-800 rounded-2xl">
            <h3 class="text-white font-semibold mb-4">¿Por qué contactarnos?</h3>
            <ul class="space-y-3">
              {[
                'Visita de diagnóstico gratuita',
                'Presupuesto sin compromiso',
                'Respuesta en menos de 24h',
                'Instalación sin obras (sistemas inalámbricos)',
              ].map(item => (
                <li class="flex items-center gap-3 text-sm text-slate-400">
                  <svg class="w-4 h-4 text-sky-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Form column -->
        <div class="lg:col-span-3 fade-up">
          <form action="https://api.web3forms.com/submit" method="POST" class="bg-slate-900 border border-slate-800 rounded-3xl p-8 sm:p-10 space-y-6" id="contact-form">
            <input type="hidden" name="access_key" value="1be34359-f4dc-4924-a45f-a5d79972775e" />
            <input type="hidden" name="subject" value="Nueva consulta desde 2SmartHome" />
            <input type="hidden" name="from_name" value="2SmartHome Web" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none !important" tabindex="-1" autocomplete="off" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="nombre" class="block text-sm font-medium text-slate-300 mb-2">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm"/>
              </div>
              <div>
                <label for="apellidos" class="block text-sm font-medium text-slate-300 mb-2">Apellidos *</label>
                <input type="text" id="apellidos" name="apellidos" required placeholder="Tus apellidos" class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm"/>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
                <input type="email" id="email" name="email" required placeholder="tu@email.com" class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm"/>
              </div>
              <div>
                <label for="telefono" class="block text-sm font-medium text-slate-300 mb-2">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" placeholder="+34 6XX XXX XXX" class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm"/>
              </div>
            </div>
            <div>
              <label for="tipo" class="block text-sm font-medium text-slate-300 mb-2">Tipo de proyecto *</label>
              <select id="tipo" name="tipo" required class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm appearance-none">
                <option value="" disabled selected class="text-slate-500">Selecciona una opción</option>
                <option value="hogar-nuevo">Vivienda nueva</option>
                <option value="hogar-existente">Vivienda existente (sin obras)</option>
                <option value="oficina">Oficina o coworking</option>
                <option value="hotel">Hotel o apartamentos</option>
                <option value="local">Local comercial</option>
                <option value="industrial">Nave industrial</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="mensaje" class="block text-sm font-medium text-slate-300 mb-2">Cuéntanos tu proyecto *</label>
              <textarea id="mensaje" name="mensaje" required rows="5" placeholder="Describe brevemente qué te gustaría automatizar, el tamaño del espacio y cualquier detalle relevante..." class="w-full px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-colors text-sm resize-none"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="privacidad" name="privacidad" required class="mt-1 w-4 h-4 rounded border-slate-600 bg-slate-800 text-sky-500 focus:ring-sky-500"/>
              <label for="privacidad" class="text-sm text-slate-400">
                He leído y acepto la <a href="/privacidad" class="text-sky-400 hover:underline">política de privacidad</a> y el tratamiento de mis datos para gestionar mi consulta.
              </label>
            </div>
            <button type="submit" class="w-full py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-all shadow-lg shadow-sky-500/25 hover:scale-[1.02] text-sm">
              Enviar consulta gratuita
            </button>
            <p id="form-success" class="hidden text-center text-green-400 text-sm font-medium">
              ¡Mensaje enviado! Te contactaremos en menos de 24 horas.
            </p>
            <p id="form-error" class="hidden text-center text-red-400 text-sm font-medium">
              Error al enviar. Por favor, inténtalo de nuevo o escríbenos directamente a <a href="mailto:info@2smarthome.es" class="underline">info@2smarthome.es</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="bg-slate-900 border-t border-slate-800">
    <div class="relative h-80">
      <iframe
        title="Ubicación de 2SmartHome – Carrer de Francesc Layret 70, Badalona"
        src="https://maps.google.com/maps?q=Carrer+de+Francesc+Layret,+70,+08911+Badalona&z=16&output=embed&hl=es"
        width="100%"
        height="100%"
        style="border:0; position:absolute; inset:0; width:100%; height:100%;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/80 to-transparent py-4 px-6 pointer-events-none">
        <p class="text-white text-sm font-medium">Carrer de Francesc Layret, 70 · 08911 Badalona, Barcelona</p>
      </div>
    </div>
    <div class="text-center py-4 bg-slate-900">
      <a href={googleMapsUrl} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sky-400 hover:text-sky-300 text-sm transition-colors font-medium">
        Abrir en Google Maps
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </section>

</Layout>

<script>
  import { track } from '@vercel/analytics';
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    success?.classList.add('hidden');
    error?.classList.add('hidden');
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const data = await response.json();
      if (response.ok && data.success) {
        track('contact_form_submitted', { lang: 'es' });
        (window as any).gtag?.('event', 'contact_form_submitted', { lang: 'es' });
        success?.classList.remove('hidden');
        form.reset();
        setTimeout(() => success?.classList.add('hidden'), 6000);
      } else {
        console.error('Web3Forms error:', data);
        error?.classList.remove('hidden');
      }
    } catch (err) {
      console.error('Fetch error:', err);
      error?.classList.remove('hidden');
    }
    if (btn) { btn.disabled = false; btn.textContent = 'Enviar consulta gratuita'; }
  });

  // Pre-fill form from URL params (?tipo=X&mensaje=Y#formulario)
  const params = new URLSearchParams(window.location.search);
  const tipoParam = params.get('tipo');
  const mensajeParam = params.get('mensaje');
  if (tipoParam) {
    const select = document.getElementById('tipo') as HTMLSelectElement;
    if (select) select.value = tipoParam;
  }
  if (mensajeParam) {
    const textarea = document.getElementById('mensaje') as HTMLTextAreaElement;
    if (textarea) textarea.value = mensajeParam;
  }
</script>
