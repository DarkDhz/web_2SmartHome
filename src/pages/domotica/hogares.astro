---
import Layout from '../../layouts/Layout.astro';

const features = [
  { icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', title: 'Iluminación inteligente', desc: 'Crea ambientes perfectos con escenas de luz automáticas. Ahorra hasta un 60% en iluminación con sensores de presencia y horarios.' },
  { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Climatización inteligente', desc: 'Tu hogar siempre a la temperatura perfecta. El sistema aprende tus rutinas y precalienta o refresca el espacio antes de que llegues.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Seguridad integrada', desc: 'Cámaras, detectores de movimiento, alarmas y cerraduras inteligentes. Vigila tu hogar en tiempo real desde el móvil.' },
  { icon: 'M4 6h16M4 12h16M4 18h16', title: 'Persianas motorizadas', desc: 'Automatiza las persianas para maximizar la luz natural, el confort térmico y la privacidad según la hora del día.' },
  { icon: 'M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z', title: 'Audio y vídeo multiroom', desc: 'Música sincronizada en todas las habitaciones, control del televisor y sistema de cine en casa completamente integrado.' },
  { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', title: 'Riego automático', desc: 'Jardines perfectamente hidratados con el mínimo consumo de agua gracias a sensores de humedad y previsión meteorológica.' },
];
---

<Layout
  title="Domótica para Hogares en Barcelona"
  description="Automatización del hogar en Barcelona, Hospitalet, Sant Cugat y área metropolitana. Iluminación inteligente, control climático, seguridad y persianas integradas en un único sistema. Instalación sin obras."
>

  <!-- HERO -->
  <section class="relative py-36 flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/img/photo-1600210492493-0946911123ea.jpg" alt="Hogar inteligente" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/80 to-slate-950/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
          <a href="/domotica" class="hover:text-slate-300 transition-colors">Domótica</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-slate-400">Hogares</span>
        </nav>
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">Automatización residencial</p>
        <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-tight mb-6">
          Tu hogar,<br/><span class="text-sky-400">como lo soñabas</span>
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed mb-8">
          Transforma tu vivienda en un hogar inteligente que te facilita la vida, recupera tu tiempo y cuida de los tuyos con la máxima seguridad.
        </p>
        <a href="/contacto" class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
          Solicitar visita gratuita
        </a>
      </div>
    </div>
  </section>

  <!-- BENEFICIOS -->
  <section class="py-20 bg-slate-900 border-y border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        {[
          { value: 'Hasta 40%', label: 'Ahorro energético' },
          { value: 'Control 24/7', label: 'Desde cualquier lugar' },
          { value: 'Sin obras', label: 'Sistemas inalámbricos' },
          { value: 'Garantía 5 años', label: 'En todos los proyectos' },
        ].map(b => (
          <div class="fade-up">
            <div class="text-2xl font-extrabold text-sky-400 mb-1">{b.value}</div>
            <div class="text-slate-400 text-sm">{b.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-up">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Qué incluye</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Todo lo que necesita tu hogar</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">Cada sistema se integra en una plataforma única que puedes controlar con voz, app o de forma totalmente automática.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div class="p-7 bg-slate-900 border border-slate-800 hover:border-sky-500/40 rounded-2xl transition-all duration-300 group fade-up" style={`transition-delay:${i*70}ms`}>
            <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center mb-5 group-hover:bg-sky-500/20 transition-colors">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={f.icon}/>
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">{f.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section class="py-24 bg-slate-900 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-up">
          <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Cómo trabajamos</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Sin obras, sin complicaciones</h2>
          <p class="text-slate-400 leading-relaxed mb-8">
            Nuestros sistemas inalámbricos se instalan en viviendas ya construidas sin necesidad de hacer obra. En la mayoría de los casos, la instalación se completa en un solo día.
          </p>
          <div class="space-y-6">
            {[
              { n: '1', t: 'Visita y estudio gratuito', d: 'Un experto analiza tu vivienda y tus necesidades sin compromiso.' },
              { n: '2', t: 'Propuesta personalizada', d: 'Diseñamos un sistema adaptado a tu hogar, presupuesto y forma de vida.' },
              { n: '3', t: 'Instalación en un día', d: 'Nuestros técnicos instalan y configuran todo de forma limpia y ordenada.' },
              { n: '4', t: 'Formación y soporte', d: 'Te enseñamos a usar el sistema y estamos disponibles 24/7 si lo necesitas.' },
            ].map(step => (
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-sky-500 flex items-center justify-center text-white text-sm font-bold">{step.n}</div>
                <div>
                  <div class="text-white font-semibold mb-1">{step.t}</div>
                  <div class="text-slate-400 text-sm">{step.d}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-2xl fade-up">
          <img src="/img/photo-1556909114-f6e7ad7d3136.jpg" alt="Instalación domótica" class="w-full h-[520px] object-cover"/>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-950 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">Transforma tu hogar hoy</h2>
      <p class="text-slate-400 mb-8">Agenda una visita gratuita y descubre cómo la domótica puede mejorar tu calidad de vida.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto" class="px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
          Solicitar visita gratuita
        </a>
        <a href="/soluciones" class="px-8 py-4 border border-slate-700 hover:border-sky-500/50 text-slate-300 hover:text-white rounded-2xl transition-all">
          Ver soluciones
        </a>
      </div>
    </div>
  </section>

</Layout>
