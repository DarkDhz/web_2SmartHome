---
import Layout from '../layouts/Layout.astro';

const _msg = `Hola, he visto vuestro portfolio y me gustaría hablar sobre un proyecto similar.
· Tipo de proyecto: [residencial / corporativo / hostelería / local]
· Mi espacio: [m²] en [zona]
· Descripción: [cuéntanos tu idea aquí]`;
const urlProyectos = `/contacto?tipo=otro&mensaje=${encodeURIComponent(_msg)}#formulario`;

const projects = [
  { title: 'Casa en Badalona', cat: 'Residencial', size: '100 m²', year: '2025', desc: 'Automatización completa de una vivienda unifamiliar en el centro de Badalona: iluminación escénica, climatización por zonas, sombreado inteligente, seguridad perimetral, audio multiroom y control de acceso integrado.', img: '/img/proyectos-casa-en-badalona.jpg', tags: ['Iluminación', 'Clima', 'Seguridad', 'Audio'] },
  { title: 'Piso en Barcelona', cat: 'Residencial', size: '90 m²', year: '2025', desc: 'Reforma domótica de un piso urbano en Barcelona con escenas de iluminación para salón y dormitorios, control climático eficiente, persianas motorizadas y sensores de presencia integrados para mejorar confort y ahorro energético.', img: '/img/proyectos-piso-barcelona.jpeg', tags: ['Iluminación', 'Persianas', 'Clima', 'Eficiencia'] },
  { title: 'Restaurante en el Eixample', cat: 'Hostelería', size: '350 m²', year: '2024', desc: 'Sistema de domótica gastronómica con escenas de iluminación por servicio, música ambiente adaptativa y control climático por zonas de sala y cocina.', img: '/img/photo-1414235077428-338989a2e8c0.jpg', tags: ['Iluminación', 'Audio', 'Clima'] },
];

const cats = ['Todos', 'Residencial', 'Hostelería'];
---

<Layout
  title="Proyectos de Domótica en Barcelona"
  description="Proyectos reales de domótica realizados en Barcelona y área metropolitana. Más de 100 instalaciones completadas."
>

  <!-- HERO -->
  <section class="relative py-32 bg-slate-900 overflow-hidden border-b border-slate-800">
    <div class="absolute inset-0 opacity-20">
      <img src="/img/photo-1600210492493-0946911123ea.jpg" alt="Vivienda inteligente con sistema de domótica residencial" class="w-full h-full object-cover"/>
      <div class="absolute inset-0 bg-slate-900"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">Nuestro portfolio</p>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white mb-6">Proyectos destacados</h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto">
        Más de 100 instalaciones completadas. Cada proyecto es único, diseñado y ejecutado a medida para cada cliente.
      </p>
    </div>
  </section>

  <!-- PROJECTS GRID -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Filter tabs -->
      <div class="flex flex-wrap gap-3 mb-14 fade-up" id="filter-tabs">
        {cats.map(cat => (
          <button
            data-filter={cat}
            class={`filter-btn px-5 py-2 rounded-xl text-sm font-medium transition-all ${cat === 'Todos' ? 'bg-sky-500 text-white' : 'bg-slate-800 text-slate-400 hover:text-white border border-slate-700 hover:border-sky-500/50'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
        {projects.map((p, i) => (
          <article class="project-card group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-sky-500/40 transition-all duration-300 fade-up" data-cat={p.cat} style={`transition-delay:${i*80}ms`}>
            <div class="relative h-52 overflow-hidden">
              <img src={p.img} alt={p.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent"></div>
              <span class="absolute top-4 left-4 px-3 py-1 bg-sky-500/90 text-white text-xs font-semibold rounded-full">{p.cat}</span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
                <span>{p.size}</span>
                <span>·</span>
                <span>{p.year}</span>
              </div>
              <h3 class="text-white font-semibold text-lg mb-3 group-hover:text-sky-400 transition-colors">{p.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-4">{p.desc}</p>
              <div class="flex flex-wrap gap-2">
                {p.tags.map(tag => (
                  <span class="px-2.5 py-1 bg-slate-800 border border-slate-700 text-slate-400 text-xs rounded-lg">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-900 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">Tu proyecto, el siguiente</h2>
      <p class="text-slate-400 mb-8">Cuéntanos tu idea y diseñamos la solución perfecta para tu espacio.</p>
      <a href={urlProyectos} class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
        Hablar sobre proyectos
      </a>
    </div>
  </section>

</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach(b => {
        b.classList.remove('bg-sky-500', 'text-white');
        b.classList.add('bg-slate-800', 'text-slate-400', 'border', 'border-slate-700');
      });
      btn.classList.add('bg-sky-500', 'text-white');
      btn.classList.remove('bg-slate-800', 'text-slate-400', 'border', 'border-slate-700');

      cards.forEach(card => {
        if (filter === 'Todos' || card.dataset.cat === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
