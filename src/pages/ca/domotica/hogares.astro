---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const imgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**', { eager: true });
const getImg = (src: string) => imgs[src.replace('/img/', '/src/assets/img/')]!.default;

const _msgVisita = `Hola, m'agradaria sol·licitar una visita gratuïta per al meu habitatge.
· Tipus: [pis / xalet / apartament / altre]
· Superfície: [m²] · Zona: [Barcelona / Badalona / altra]
· M'interessa: [il·luminació / clima / seguretat / persianes / tot]`;
const _msgEstudi = `Hola, vull agendar un estudi de domòtica per a la meva llar.
· Tipus d'habitatge: [pis / xalet] · Superfície: [m²]
· Zona: [Barcelona / Badalona / Sant Cugat / altra]
· Sistemes d'interès: [il·luminació / clima / seguretat / persianes / àudio]`;
const urlVisita = `/ca/contacto?tipo=hogar-existente&mensaje=${encodeURIComponent(_msgVisita)}#formulario`;
const urlEstudi = `/ca/contacto?tipo=hogar-existente&mensaje=${encodeURIComponent(_msgEstudi)}#formulario`;

const SITE_URL = 'https://www.2smarthome.es';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Domòtica per a Llars a Barcelona',
  description: 'Automatització de la llar a Barcelona i àrea metropolitana. Il·luminació intel·ligent, control climàtic, seguretat i persianes en un únic sistema. Instal·lació sense obres.',
  provider: { '@type': 'LocalBusiness', name: '2SmartHome', url: SITE_URL },
  areaServed: [
    { '@type': 'City', name: 'Barcelona' },
    { '@type': 'City', name: 'Badalona' },
    { '@type': 'City', name: 'Hospitalet de Llobregat' },
    { '@type': 'City', name: 'Sant Cugat del Vallès' },
  ],
  serviceType: 'Home Automation',
  url: `${SITE_URL}/ca/domotica/hogares`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inici', item: `${SITE_URL}/ca` },
    { '@type': 'ListItem', position: 2, name: 'Domòtica', item: `${SITE_URL}/ca/domotica` },
    { '@type': 'ListItem', position: 3, name: 'Llars', item: `${SITE_URL}/ca/domotica/hogares` },
  ],
};

const features = [
  { icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', title: 'Il·luminació intel·ligent', desc: 'Crea ambients perfectes amb escenes de llum automàtiques. Estalvia fins a un 60% en il·luminació amb sensors de presència i horaris.' },
  { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Climatització intel·ligent', desc: 'La teva llar sempre a la temperatura perfecta. El sistema aprèn les teves rutines i preescalfa o refresca l\'espai abans que arribis.' },
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Seguretat integrada', desc: 'Càmeres, detectors de moviment, alarmes i panys intel·ligents. Vigila la teva llar en temps real des del mòbil.' },
  { icon: 'M4 6h16M4 12h16M4 18h16', title: 'Persianes motoritzades', desc: 'Automatitza les persianes per maximitzar la llum natural, el confort tèrmic i la privacitat segons l\'hora del dia.' },
  { icon: 'M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z', title: 'Àudio i vídeo multiroom', desc: 'Música sincronitzada a totes les habitacions, control del televisor i sistema de cinema en casa completament integrat.' },
  { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', title: 'Reg automàtic', desc: 'Jardins perfectament hidratats amb el mínim consum d\'aigua gràcies a sensors d\'humitat i previsió meteorològica.' },
];
---

<Layout
  title="Domòtica per a Llars a Barcelona"
  description="Automatització de la llar a Barcelona i àrea metropolitana. Il·luminació intel·ligent, control climàtic, seguretat i persianes integrades. Instal·lació sense obres."
  lang="ca"
  schemas={[serviceSchema, breadcrumbSchema]}
>

  <!-- HERO -->
  <section class="relative py-36 flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImg('/img/photo-1600210492493-0946911123ea.jpg')} alt="Automatització de llar intel·ligent a Barcelona sense obres, amb control des del mòbil" width={1920} quality={70} fetchpriority="high" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/80 to-slate-950/30"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
          <a href="/ca/domotica" class="hover:text-slate-300 transition-colors">Inici domòtica</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-slate-400">Llars</span>
        </nav>
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">Automatització residencial</p>
        <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-tight mb-6">
          La teva llar,<br/><span class="text-sky-400">com la somniaves</span>
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed mb-8">
          Transforma el teu habitatge en una llar intel·ligent que et facilita la vida, recupera el teu temps i cuida dels teus amb la màxima seguretat.
        </p>
        <a href={urlVisita} rel="nofollow" class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
          Sol·licitar visita residencial
        </a>
      </div>
    </div>
  </section>

  <!-- BENEFICIS -->
  <section class="py-20 bg-slate-900 border-y border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        {[
          { value: 'Fins al 40%', label: 'Estalvi energètic' },
          { value: 'Control 24/7', label: 'Des de qualsevol lloc' },
          { value: 'Sense obres', label: 'Sistemes sense fils' },
          { value: 'Garantia 5 anys', label: 'En tots els projectes' },
        ].map(b => (
          <div class="fade-up">
            <div class="text-2xl font-extrabold text-sky-400 mb-1">{b.value}</div>
            <div class="text-slate-400 text-sm">{b.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FUNCIONALITATS -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-up">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Què inclou</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Tot el que necessita la teva llar</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">Cada sistema s'integra en una plataforma única que pots controlar per veu, app o de forma totalment automàtica.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div class="p-7 bg-slate-900 border border-slate-800 hover:border-sky-500/40 rounded-2xl transition-all duration-300 group fade-up" style={`transition-delay:${i*70}ms`}>
            <div class="w-12 h-12 rounded-xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center mb-5 group-hover:bg-sky-500/20 transition-colors">
              <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={f.icon}/>
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-2">{f.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCÉS -->
  <section class="py-24 bg-slate-900 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="fade-up">
          <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">Com treballem</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Sense obres, sense complicacions</h2>
          <p class="text-slate-400 leading-relaxed mb-8">
            Els nostres sistemes sense fils s'instal·len en habitatges ja construïts sense necessitat de fer obra. En la majoria dels casos, la instal·lació es completa en un sol dia.
          </p>
          <div class="space-y-6">
            {[
              { n: '1', t: 'Visita i estudi gratuït', d: 'Un expert analitza el teu habitatge i les teves necessitats sense compromís.' },
              { n: '2', t: 'Proposta personalitzada', d: 'Dissenyem un sistema adaptat a la teva llar, pressupost i forma de vida.' },
              { n: '3', t: 'Instal·lació ràpida', d: 'Els nostres tècnics instal·len i configuren tot de forma neta i ordenada.' },
              { n: '4', t: 'Formació i suport', d: 'T\'ensenyem a utilitzar el sistema i estem disponibles 24/7 si ens necessites.' },
            ].map(step => (
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-sky-500 flex items-center justify-center text-white text-sm font-bold">{step.n}</div>
                <div>
                  <div class="text-white font-semibold mb-1">{step.t}</div>
                  <div class="text-slate-400 text-sm">{step.d}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-3xl overflow-hidden shadow-2xl fade-up">
          <Image src={getImg('/img/photo-1556909114-f6e7ad7d3136.jpg')} alt="Tècnic de 2SmartHome instal·lant sistema domòtic sense fils en habitatge de Barcelona" width={1200} class="w-full h-[520px] object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-950 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">Transforma la teva llar avui</h2>
      <p class="text-slate-400 mb-8">Agenda una visita gratuïta i descobreix com la domòtica pot millorar la teva qualitat de vida.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={urlEstudi} rel="nofollow" class="px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
          Agendar estudi de la llar
        </a>
        <a href="/ca/soluciones" class="px-8 py-4 border border-slate-700 hover:border-sky-500/50 text-slate-300 hover:text-white rounded-2xl transition-all">
          Veure solucions domòtiques
        </a>
      </div>
    </div>
  </section>

</Layout>
