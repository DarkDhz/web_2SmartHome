---
import Layout from '../../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const imgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**', { eager: true });
const getImg = (src: string) => imgs[src.replace('/img/', '/src/assets/img/')]!.default;

const _msg = `Hola, m'agradaria una consulta sobre domòtica per al meu projecte.
· Tipus d'espai: [llar / oficina / local / altre]
· Superfície aproximada: [m²]
· Quins sistemes m'interessen? [il·luminació / clima / seguretat / tot]`;
const urlConsulta = `/ca/contacto?tipo=hogar-existente&mensaje=${encodeURIComponent(_msg)}#formulario`;
---

<Layout
  title="Domòtica a Barcelona – Llars i Empreses"
  description="Solucions de domòtica a Barcelona i àrea metropolitana: Hospitalet, Badalona, Sant Cugat, Terrassa i Sabadell. Automatització residencial i empresarial intel·ligent, eficient i connectada."
  lang="ca"
>

  <!-- HERO -->
  <section class="relative py-32 flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image src={getImg('/img/photo-1586023492125-27b2c045efd7.jpg')} alt="Sistema de domòtica instal·lat en habitatge modern de l'àrea metropolitana de Barcelona" width={1920} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/80 to-slate-950/50"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">Domòtica</p>
        <h1 class="text-5xl sm:text-6xl font-extrabold text-white leading-tight mb-6">
          Espais que<br/><span class="text-sky-400">pensen per tu</span>
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed mb-8">
          La domòtica integra tecnologia a la teva llar o empresa per automatitzar tasques, millorar la seguretat, optimitzar el consum energètic i augmentar el teu confort.
        </p>
        <div class="flex gap-4">
          <a href="/ca/domotica/hogares" class="px-6 py-3 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-all shadow-lg shadow-sky-500/25">Per a llars</a>
          <a href="/ca/domotica/empresas" class="px-6 py-3 border border-slate-600 hover:border-sky-500 text-white rounded-xl transition-all">Per a empreses</a>
        </div>
      </div>
    </div>
  </section>

  <!-- QUÈ ÉS -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-up">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">La tecnologia al servei de la teva vida</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Què és la domòtica?</h2>
        <p class="text-slate-400 max-w-3xl mx-auto leading-relaxed">
          La domòtica és el conjunt de sistemes que permeten controlar i automatitzar els elements d'una llar o edifici: il·luminació, clima, seguretat, persianes, electrodomèstics i molt més. Tot des d'una sola app o mitjançant rutines automàtiques.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        {[
          { icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z', title: 'Control des del mòbil', desc: 'Gestiona la teva llar o empresa des de qualsevol lloc amb una aplicació intuïtiva.' },
          { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'Rutines automàtiques', desc: 'Programa accions que s\'executin soles: apagar llums en sortir, regular el clima en tornar.' },
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Estalvi energètic', desc: 'Redueix la teva factura fins a un 40% gràcies a l\'optimització intel·ligent del consum.' },
        ].map((item, i) => (
          <div class="text-center p-8 bg-slate-900 border border-slate-800 rounded-2xl fade-up" style={`transition-delay:${i*100}ms`}>
            <div class="w-14 h-14 rounded-2xl bg-sky-500/10 border border-sky-500/20 flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon}/>
              </svg>
            </div>
            <h3 class="text-white font-semibold text-lg mb-3">{item.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <article class="group relative rounded-3xl overflow-hidden fade-up">
          <Image src={getImg('/img/photo-1600210492493-0946911123ea.jpg')} alt="Llars intel·ligents" width={800} class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/60 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <span class="px-3 py-1 bg-sky-500/20 border border-sky-500/40 text-sky-400 text-xs font-semibold rounded-full">Residencial</span>
            <h3 class="text-white text-2xl font-bold mt-3 mb-2">Llars intel·ligents</h3>
            <p class="text-slate-300 text-sm mb-4">Per a habitatges que volen més confort, seguretat i estalvi energètic.</p>
            <a href="/ca/domotica/hogares" class="inline-flex items-center gap-2 text-sky-400 font-medium text-sm">
              <span>Domòtica per a llars</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>

        <article class="group relative rounded-3xl overflow-hidden fade-up" style="transition-delay:120ms">
          <Image src={getImg('/img/photo-1497366216548-37526070297c.jpg')} alt="Empreses intel·ligents" width={800} class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/60 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-8">
            <span class="px-3 py-1 bg-sky-500/20 border border-sky-500/40 text-sky-400 text-xs font-semibold rounded-full">Corporatiu</span>
            <h3 class="text-white text-2xl font-bold mt-3 mb-2">Solucions per a empreses</h3>
            <p class="text-slate-300 text-sm mb-4">Optimitza la gestió d'oficines, hotels, locals i edificis comercials.</p>
            <a href="/ca/domotica/empresas" class="inline-flex items-center gap-2 text-sky-400 font-medium text-sm">
              <span>Domòtica per a empreses</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- PROCÉS -->
  <section class="py-24 bg-slate-900 border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-up">
        <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-3">El nostre procés</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">De la idea a la realitat</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { n: '01', title: 'Consulta gratuïta', desc: 'Analitzem les teves necessitats i objectius sense compromís.' },
          { n: '02', title: 'Disseny personalitzat', desc: 'Creem un projecte a mida amb els millors sistemes del mercat.' },
          { n: '03', title: 'Instal·lació professional', desc: 'El nostre equip tècnic instal·la i configura tot sense molèsties.' },
          { n: '04', title: 'Suport continu', desc: 'T\'acompanyem amb manteniment i assistència 24/7.' },
        ].map((step, i) => (
          <div class="relative p-7 bg-slate-800/50 border border-slate-700 rounded-2xl fade-up" style={`transition-delay:${i*80}ms`}>
            <div class="text-5xl font-extrabold text-slate-800 mb-4 select-none">{step.n}</div>
            <h3 class="text-white font-semibold text-lg mb-2">{step.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-950 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">Per on comencem?</h2>
      <p class="text-slate-400 mb-8">Explica'ns el teu projecte i t'oferirem la solució més adequada.</p>
      <a href={urlConsulta} class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
        Sol·licitar consulta gratuïta
      </a>
    </div>
  </section>

</Layout>
