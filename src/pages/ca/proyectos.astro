---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const imgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/img/**', { eager: true });
const getImg = (src: string) => imgs[src.replace('/img/', '/src/assets/img/')]!.default;

const _msg = `Hola, he vist el vostre portfolio i m'agradaria parlar sobre un projecte similar.
· Tipus de projecte: [residencial / corporatiu / hostaleria / local]
· El meu espai: [m²] a [zona]
· Descripció: [explica'ns la teva idea aquí]`;
const urlProyectos = `/ca/contacto?tipo=otro&mensaje=${encodeURIComponent(_msg)}#formulario`;

const projects = [
  { title: 'Casa a Badalona', cat: 'Residencial', size: '100 m²', year: '2025', desc: 'Automatització completa d\'un habitatge unifamiliar al centre de Badalona: il·luminació escènica, climatització per zones, ombreig intel·ligent, seguretat perimetral, àudio multiroom i control d\'accés integrat.', img: '/img/proyectos-casa-en-badalona.jpg', tags: ['Il·luminació', 'Clima', 'Seguretat', 'Àudio'] },
  { title: 'Pis a Barcelona', cat: 'Residencial', size: '90 m²', year: '2025', desc: 'Reforma domòtica d\'un pis urbà a Barcelona amb escenes d\'il·luminació per saló i dormitoris, control climàtic eficient, persianes motoritzades i sensors de presència integrats per millorar confort i estalvi energètic.', img: '/img/proyectos-piso-barcelona.jpeg', tags: ['Il·luminació', 'Persianes', 'Clima', 'Eficiència'] },
  { title: 'Restaurant a l\'Eixample', cat: 'Hostaleria', size: '350 m²', year: '2024', desc: 'Sistema de domòtica gastronòmica amb escenes d\'il·luminació per servei, música ambient adaptativa i control climàtic per zones de sala i cuina.', img: '/img/photo-1414235077428-338989a2e8c0.jpg', tags: ['Il·luminació', 'Àudio', 'Clima'] },
];

const cats = ['Tots', 'Residencial', 'Hostaleria'];
---

<Layout
  title="Projectes de Domòtica a Barcelona"
  description="Projectes reals de domòtica realitzats a Barcelona i àrea metropolitana. Més de 100 instal·lacions completades."
  lang="ca"
>

  <!-- HERO -->
  <section class="relative py-32 bg-slate-900 overflow-hidden border-b border-slate-800">
    <div class="absolute inset-0 opacity-20">
      <Image src={getImg('/img/photo-1600210492493-0946911123ea.jpg')} alt="Habitatge intel·ligent amb sistema de domòtica residencial" width={1920} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-slate-900"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sky-400 font-medium text-sm uppercase tracking-wider mb-4">El nostre portfolio</p>
      <h1 class="text-5xl sm:text-6xl font-extrabold text-white mb-6">Projectes destacats</h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto">
        Més de 100 instal·lacions completades. Cada projecte és únic, dissenyat i executat a mida per a cada client.
      </p>
    </div>
  </section>

  <!-- PROJECTS GRID -->
  <section class="py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-3 mb-14 fade-up" id="filter-tabs">
        {cats.map(cat => (
          <button
            data-filter={cat}
            class={`filter-btn px-5 py-2 rounded-xl text-sm font-medium transition-all ${cat === 'Tots' ? 'bg-sky-500 text-white' : 'bg-slate-800 text-slate-400 hover:text-white border border-slate-700 hover:border-sky-500/50'}`}
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="projects-grid">
        {projects.map((p, i) => (
          <article class="project-card group bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden hover:border-sky-500/40 transition-all duration-300 fade-up" data-cat={p.cat} style={`transition-delay:${i*80}ms`}>
            <div class="relative h-52 overflow-hidden">
              <Image src={getImg(p.img)} alt={p.title} width={800} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent"></div>
              <span class="absolute top-4 left-4 px-3 py-1 bg-sky-500/90 text-white text-xs font-semibold rounded-full">{p.cat}</span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
                <span>{p.size}</span>
                <span>·</span>
                <span>{p.year}</span>
              </div>
              <h3 class="text-white font-semibold text-lg mb-3 group-hover:text-sky-400 transition-colors">{p.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed mb-4">{p.desc}</p>
              <div class="flex flex-wrap gap-2">
                {p.tags.map(tag => (
                  <span class="px-2.5 py-1 bg-slate-800 border border-slate-700 text-slate-400 text-xs rounded-lg">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-900 border-t border-slate-800">
    <div class="max-w-3xl mx-auto px-4 text-center fade-up">
      <h2 class="text-3xl font-bold text-white mb-4">El teu projecte, el següent</h2>
      <p class="text-slate-400 mb-8">Explica'ns la teva idea i dissenyem la solució perfecta per al teu espai.</p>
      <a href={urlProyectos} class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-2xl transition-all shadow-2xl shadow-sky-500/25 hover:scale-105">
        Parlar sobre projectes
      </a>
    </div>
  </section>

</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      buttons.forEach(b => {
        b.classList.remove('bg-sky-500', 'text-white');
        b.classList.add('bg-slate-800', 'text-slate-400', 'border', 'border-slate-700');
      });
      btn.classList.add('bg-sky-500', 'text-white');
      btn.classList.remove('bg-slate-800', 'text-slate-400', 'border', 'border-slate-700');

      cards.forEach(card => {
        if (filter === 'Tots' || card.dataset.cat === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
