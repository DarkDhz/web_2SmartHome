---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { getImage } from 'astro:assets';
import defaultImgSrc from '../assets/img/principal-hero-img.jpeg';
import logoSrc from '../assets/img/logo-navbar.png';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noIndex?: boolean;
  schemas?: object[];
  lang?: 'es' | 'ca';
}

const SITE_URL = 'https://www.2smarthome.es';
const SITE_NAME = '2SmartHome';
const _defaultImgOpt = await getImage({ src: defaultImgSrc, format: 'jpeg', width: 1200 });
const _logoOpt = await getImage({ src: logoSrc, format: 'png', width: 300 });
const DEFAULT_IMAGE = `${SITE_URL}${_defaultImgOpt.src}`;
const LOGO_IMAGE = `${SITE_URL}${_logoOpt.src}`;
const GOOGLE_MAPS_URL = 'https://www.google.es/maps/place/2SmartHome/@41.4506426,2.2458014,17z/data=!3m1!4b1!4m6!3m5!1s0xab2d40321309cb1d:0xbef6271c31a9e354!8m2!3d41.4506386!4d2.2483763!16s%2Fg%2F11yvvpdd3y';

const {
  title,
  seoTitle,
  description = 'Empresa de domótica en Barcelona. Automatizamos hogares y empresas en Barcelona, Hospitalet, Sant Cugat, Badalona y toda el área metropolitana. Presupuesto gratuito.',
  image = DEFAULT_IMAGE,
  canonical = new URL(Astro.url.pathname, SITE_URL).href,
  noIndex = false,
  schemas = [],
  lang = 'es',
} = Astro.props;

const pathname = Astro.url.pathname;
const esAlternate = lang === 'ca'
  ? new URL(pathname.replace(/^\/ca\/?/, '/').replace('//', '/'), SITE_URL).href
  : canonical;
const caAlternate = lang === 'ca'
  ? canonical
  : new URL(`/ca${pathname === '/' ? '' : pathname}`, SITE_URL).href;

const fullTitle = seoTitle ?? `${title} | ${SITE_NAME}`;
const whatsappPhone = '34660877744';
const whatsappMessages: Record<string, string> = {
  '/': 'Hola 2SmartHome, vengo de la página principal y quiero información sobre domótica.',
  '/domotica': 'Hola 2SmartHome, me interesa conocer vuestras soluciones de domótica.',
  '/domotica/hogares': 'Hola 2SmartHome, quiero información sobre domótica para mi hogar.',
  '/domotica/empresas': 'Hola 2SmartHome, quiero información sobre domótica para mi empresa.',
  '/soluciones': 'Hola 2SmartHome, vengo de la página de soluciones y quiero asesoramiento.',
  '/proyectos': 'Hola 2SmartHome, he visto vuestros proyectos y quiero hablar sobre el mío.',
  '/quienes-somos': 'Hola 2SmartHome, vengo de la página Quiénes somos y quiero contactar con vosotros.',
  '/recursos': 'Hola 2SmartHome, vengo de la página de recursos y tengo una consulta.',
  '/contacto': 'Hola 2SmartHome, vengo de la página de contacto y quiero pedir información.',
  '/ca': 'Hola 2SmartHome, vinc de la pàgina principal i vull informació sobre domòtica.',
  '/ca/domotica': 'Hola 2SmartHome, m\'interessa conèixer les vostres solucions de domòtica.',
  '/ca/domotica/hogares': 'Hola 2SmartHome, vull informació sobre domòtica per a la meva llar.',
  '/ca/domotica/empresas': 'Hola 2SmartHome, vull informació sobre domòtica per a la meva empresa.',
  '/ca/soluciones': 'Hola 2SmartHome, vinc de la pàgina de solucions i vull assessorament.',
  '/ca/proyectos': 'Hola 2SmartHome, he vist els vostres projectes i vull parlar del meu.',
  '/ca/quienes-somos': 'Hola 2SmartHome, vinc de la pàgina Qui som i vull contactar amb vosaltres.',
  '/ca/recursos': 'Hola 2SmartHome, vinc de la pàgina de recursos i tinc una consulta.',
  '/ca/contacto': 'Hola 2SmartHome, vinc de la pàgina de contacte i vull demanar informació.',
};
const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const whatsappMessage = whatsappMessages[normalizedPath] ?? whatsappMessages['/'];
const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodeURIComponent(whatsappMessage)}`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
  "@id": `${SITE_URL}/#organization`,
  "name": "2SmartHome",
  "alternateName": "2SmartHome Domótica Barcelona",
  "description": "Empresa especializada en domótica e instalaciones inteligentes en Barcelona y área metropolitana. Automatización de hogares y empresas, iluminación inteligente, control climático, seguridad y gestión energética.",
  "url": SITE_URL,
  "hasMap": GOOGLE_MAPS_URL,
  "logo": {
    "@type": "ImageObject",
    "url": LOGO_IMAGE
  },
  "image": DEFAULT_IMAGE,
  "telephone": "+34660877744",
  "email": "info@2smarthome.es",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Carrer de Francesc Layret, 70",
    "addressLocality": "Badalona",
    "postalCode": "08911",
    "addressRegion": "Cataluña",
    "addressCountry": "ES"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 41.4506386,
    "longitude": 2.2483763
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "20:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "09:30",
      "closes": "20:00"
    }
  ],
  "areaServed": [
    { "@type": "City", "name": "Barcelona" },
    { "@type": "City", "name": "L'Hospitalet de Llobregat" },
    { "@type": "City", "name": "Badalona" },
    { "@type": "City", "name": "Terrassa" },
    { "@type": "City", "name": "Sabadell" },
    { "@type": "City", "name": "Mataró" },
    { "@type": "City", "name": "Santa Coloma de Gramenet" },
    { "@type": "City", "name": "Cornellà de Llobregat" },
    { "@type": "City", "name": "Sant Boi de Llobregat" },
    { "@type": "City", "name": "El Prat de Llobregat" },
    { "@type": "City", "name": "Rubí" },
    { "@type": "City", "name": "Viladecans" },
    { "@type": "City", "name": "Gavà" },
    { "@type": "City", "name": "Castelldefels" },
    { "@type": "City", "name": "Esplugues de Llobregat" },
    { "@type": "City", "name": "Sant Cugat del Vallès" },
    { "@type": "City", "name": "Cerdanyola del Vallès" },
    { "@type": "City", "name": "Granollers" },
    { "@type": "City", "name": "Mollet del Vallès" },
    { "@type": "City", "name": "Sitges" },
    { "@type": "City", "name": "Vilanova i la Geltrú" },
    { "@type": "City", "name": "Premià de Mar" },
    { "@type": "City", "name": "Montgat" },
    { "@type": "City", "name": "Tiana" },
    { "@type": "City", "name": "Sant Adrià de Besòs" },
    { "@type": "AdministrativeArea", "name": "Área Metropolitana de Barcelona" },
    { "@type": "AdministrativeArea", "name": "Cataluña" }
  ],
  "serviceType": [
    "Domótica residencial",
    "Domótica empresarial",
    "Automatización del hogar",
    "Iluminación inteligente",
    "Control climático inteligente",
    "Seguridad inteligente",
    "Control de acceso",
    "Gestión energética",
    "Persianas motorizadas",
    "Smart home"
  ],
  "priceRange": "€€",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Transferencia bancaria, tarjeta de crédito",
  "sameAs": [
    "https://x.com/2SmartHomeES",
    "https://www.tiktok.com/@2smarthomees?lang=es-419",
    "https://www.facebook.com/people/2SmartHome/61586422361510/",
    "https://www.linkedin.com/company/2smarthomees/",
    "https://www.instagram.com/2smarthome.es/"
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content="2SmartHome" />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es-ES" href={esAlternate} />
    <link rel="alternate" hreflang="ca-ES" href={caAlternate} />
    <link rel="alternate" hreflang="x-default" href={esAlternate} />

    <!-- GEO / Local SEO -->
    <meta name="geo.region" content="ES-CT" />
    <meta name="geo.placename" content="Badalona, Cataluña, España" />
    <meta name="geo.position" content="41.4506386;2.2483763" />
    <meta name="ICBM" content="41.4506386, 2.2483763" />
    <meta name="DC.title" content={fullTitle} />
    <meta name="DC.description" content={description} />
    <meta name="DC.language" content={lang} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={lang === 'ca' ? 'ca_ES' : 'es_ES'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@2SmartHomeES" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <!-- JSON-LD: LocalBusiness + Organization -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {schemas.map(s => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Vercel Analytics -->
    <Analytics />
    <SpeedInsights />

    <!-- Google Analytics 4 with Consent Mode v2 (RGPD/EEA) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GS31FY434F"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500,
      });
      try {
        if (localStorage.getItem('cookie_consent') === 'accepted') {
          gtag('consent', 'update', {
            analytics_storage: 'granted',
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
          });
        }
      } catch(e) {}
      gtag('js', new Date());
      gtag('config', 'G-GS31FY434F');
    </script>

    <style>
      html { scroll-behavior: smooth; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #020617; }
      ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #475569; }
      .fade-up { opacity: 0; transform: translateY(28px); transition: opacity 0.65s ease, transform 0.65s ease; }
      .fade-up.visible { opacity: 1; transform: translateY(0); }
    </style>
  </head>
  <body class="bg-slate-950 text-white antialiased font-sans">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-sky-500 focus:text-white focus:rounded-xl focus:font-semibold focus:shadow-lg">
      {lang === 'ca' ? 'Saltar al contingut' : 'Saltar al contenido'}
    </a>
    <Header />
    <main id="main-content" class="pt-20">
      <slot />
    </main>
    <a
      id="whatsapp-btn"
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-5 right-5 z-50 flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-xl shadow-black/30 ring-1 ring-white/20 transition-all duration-200 hover:-translate-y-1 hover:bg-[#20bd5a] hover:shadow-[#25D366]/30 focus:outline-none focus:ring-4 focus:ring-[#25D366]/40 sm:bottom-6 sm:right-6 sm:h-16 sm:w-16"
    >
      <svg class="h-7 w-7 sm:h-8 sm:w-8" viewBox="0 0 448 512" aria-hidden="true" fill="currentColor">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32 101.5 32 2 131.5 2 253.9c0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.5 224.1-221.9 0-59.3-25.2-115-67.1-157.1zM223.9 438.7h-.1c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z" />
      </svg>
    </a>
    <Footer />
    <CookieBanner lang={lang} />
    <script>
      import { track } from '@vercel/analytics';

      // Fire a custom event to both Vercel Analytics and GA4.
      const fire = (name: string, props: Record<string, string>) => {
        track(name, props);
        (window as any).gtag?.('event', name, props);
      };

      const obs = new IntersectionObserver(
        entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.1 }
      );
      document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));

      document.getElementById('whatsapp-btn')?.addEventListener('click', () => {
        fire('whatsapp_click', { page: window.location.pathname });
      });

      // Delegated tracking for conversion links across every page (ES + CA):
      // phone calls, email clicks, and contact-page CTAs.
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement)?.closest?.('a');
        if (!link) return;
        const href = link.getAttribute('href') || '';
        const page = window.location.pathname;
        if (href.startsWith('tel:')) {
          fire('phone_click', { page });
        } else if (href.startsWith('mailto:')) {
          fire('email_click', { page });
        } else if (href.includes('/contacto') && !page.includes('/contacto')) {
          fire('contact_cta_clicked', { page, text: (link.textContent || '').trim().slice(0, 60) });
        }
      });
    </script>
  </body>
</html>
