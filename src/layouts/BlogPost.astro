---
import Layout from './Layout.astro';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const blogImgs = import.meta.glob<{ default: ImageMetadata }>('/src/assets/blog_imgs/**', { eager: true });
const getBlogImg = (src: string) => blogImgs[src.replace('/blog_imgs/', '/src/assets/blog_imgs/')]?.default;

interface Props {
  title: string;
  description: string;
  cat: string;
  date: string;
  time: string;
  img: string;
  imgAlt?: string;
  lang?: 'es' | 'ca';
  cta?: {
    eyebrow?: string;
    title?: string;
    text?: string;
    button?: string;
    href?: string;
    tipo?: string;
    mensaje?: string;
  };
}

const {
  title,
  description,
  cat,
  date,
  time,
  img,
  imgAlt = title,
  lang = 'es',
  cta = {},
} = Astro.props;

const ui = lang === 'ca' ? {
  home: 'Inici',
  resources: 'Recursos',
  readTime: 'de lectura',
  backToBlog: 'Tornar al blog de recursos',
  defaultCtaEyebrow: 'Llest per fer el salt?',
  defaultCtaTitle: 'Parlem del teu projecte',
  defaultCtaText: 'Visita gratuïta i pressupost sense compromís. Els nostres experts t\'assessoren sobre la millor solució per a la teva llar o empresa.',
  defaultCtaButton: 'Sol·licitar assessorament gratuït',
} : {
  home: 'Inicio',
  resources: 'Recursos',
  readTime: 'de lectura',
  backToBlog: 'Volver al blog de recursos',
  defaultCtaEyebrow: '¿Listo para dar el salto?',
  defaultCtaTitle: 'Hablemos de tu proyecto',
  defaultCtaText: 'Visita gratuita y presupuesto sin compromiso. Nuestros expertos te asesoran sobre la mejor solución para tu hogar o empresa.',
  defaultCtaButton: 'Solicitar asesoramiento gratuito',
};

const SITE_URL = 'https://www.2smarthome.es';
const monthMap: Record<string, string> = {
  Jan: '01', Feb: '02', Mar: '03', Apr: '04', May: '05', Jun: '06',
  Jul: '07', Aug: '08', Sep: '09', Oct: '10', Nov: '11', Dec: '12',
};
const [mon, yr] = date.split(' ');
const dateISO = `${yr}-${monthMap[mon] ?? '01'}-01`;
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const _imgMeta = getBlogImg(img);
const _imgOpt = _imgMeta ? await getImage({ src: _imgMeta, format: 'jpeg', width: 1200 }) : null;
const imageUrl = _imgOpt ? `${SITE_URL}${_imgOpt.src}` : `${SITE_URL}${img}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: imageUrl,
  datePublished: dateISO,
  dateModified: dateISO,
  author: { '@type': 'Organization', name: '2SmartHome', url: SITE_URL },
  publisher: {
    '@type': 'Organization',
    name: '2SmartHome',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/img/logo-navbar.png` },
  },
  url: canonical,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: ui.home, item: lang === 'ca' ? `${SITE_URL}/ca` : `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: ui.resources, item: `${SITE_URL}${resourcesPath}` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};

const contactPath = lang === 'ca' ? '/ca/contacto' : '/contacto';
const resourcesPath = lang === 'ca' ? '/ca/recursos' : '/recursos';

const finalCta = {
  eyebrow: ui.defaultCtaEyebrow,
  title: ui.defaultCtaTitle,
  text: ui.defaultCtaText,
  button: ui.defaultCtaButton,
  href: `${contactPath}#formulario`,
  tipo: undefined as string | undefined,
  mensaje: undefined as string | undefined,
  ...cta,
};

const ctaHref = (finalCta.tipo || finalCta.mensaje)
  ? `${contactPath}?${new URLSearchParams({
      ...(finalCta.tipo ? { tipo: finalCta.tipo } : {}),
      ...(finalCta.mensaje ? { mensaje: finalCta.mensaje } : {}),
    }).toString()}#formulario`
  : finalCta.href;
---

<Layout title={title} description={description} noIndex={false} schemas={[articleSchema, breadcrumbSchema]} lang={lang}>

  <!-- Reading progress bar -->
  <div class="fixed top-20 left-0 right-0 z-40 h-0.5 bg-slate-800">
    <div id="reading-progress" class="h-full bg-sky-500" style="width:0%;transition:none"></div>
  </div>

  <!-- Article hero -->
  <section class="bg-slate-900 border-b border-slate-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-500 mb-10">
        <a href={lang === 'ca' ? '/ca' : '/'} class="hover:text-sky-400 transition-colors">{ui.home}</a>
        <svg class="w-3 h-3 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href={resourcesPath} class="hover:text-sky-400 transition-colors">{ui.resources}</a>
        <svg class="w-3 h-3 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-400 truncate">{title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-sky-500/20 text-sky-400 text-xs font-semibold rounded-lg border border-sky-500/30 uppercase tracking-wide">{cat}</span>
        <span class="text-slate-500 text-sm">{date}</span>
        <span class="text-slate-600">·</span>
        <span class="text-slate-500 text-sm flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {time} {ui.readTime}
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6">{title}</h1>
      <p class="text-lg sm:text-xl text-slate-300 leading-relaxed">{description}</p>
    </div>
  </section>

  <!-- Featured image -->
  <div class="bg-slate-950 pt-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-2xl border border-slate-800 h-64 sm:h-80 lg:h-[420px]">
        {_imgMeta && <Image src={_imgMeta} alt={imgAlt} width={1200} class="w-full h-full object-cover" loading="eager" />}
      </div>
    </div>
  </div>

  <!-- Article body -->
  <div class="bg-slate-950 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="article-body">
        <slot />
      </div>

      <!-- Bottom CTA -->
      <div class="mt-16 p-8 bg-slate-900 border border-sky-500/20 rounded-2xl text-center">
        <p class="text-sky-400 text-xs font-semibold uppercase tracking-wider mb-3">{finalCta.eyebrow}</p>
        <h3 class="text-2xl font-bold text-white mb-3">{finalCta.title}</h3>
        <p class="text-slate-400 mb-6 max-w-sm mx-auto text-sm leading-relaxed">{finalCta.text}</p>
        <a href={ctaHref} class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-all shadow-lg shadow-sky-500/25 hover:scale-105">
          {finalCta.button}
        </a>
      </div>
      <!-- Back to blog -->
      <div class="mt-10 text-center">
        <a href={resourcesPath} class="inline-flex items-center gap-2 text-sky-400 hover:text-sky-300 transition-colors font-medium text-sm">
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          {ui.backToBlog}
        </a>
      </div>
    </div>
  </div>

</Layout>

<style>
  .article-body :global(h2) {
    color: #f1f5f9;
    font-size: 1.625rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid #1e293b;
  }
  .article-body :global(h3) {
    color: #e2e8f0;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .article-body :global(p) {
    color: #94a3b8;
    font-size: 1.0625rem;
    line-height: 1.85;
    margin-bottom: 1.5rem;
  }
  .article-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  .article-body :global(ul li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: #94a3b8;
    margin-bottom: 0.75rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .article-body :global(ul li::before) {
    content: "→";
    color: #38bdf8;
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-weight: 600;
  }
  .article-body :global(ol) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
    counter-reset: list-counter;
  }
  .article-body :global(ol li) {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    counter-increment: list-counter;
  }
  .article-body :global(ol li::before) {
    content: counter(list-counter);
    background: #0ea5e9;
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .article-body :global(strong) {
    color: #e2e8f0;
    font-weight: 600;
  }
  .article-body :global(em) {
    color: #7dd3fc;
    font-style: italic;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid #0ea5e9;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    background: rgba(14, 165, 233, 0.06);
    border-radius: 0 0.75rem 0.75rem 0;
  }
  .article-body :global(blockquote p) {
    color: #bae6fd;
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 0;
    font-style: italic;
  }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid #1e293b;
    margin: 2.5rem 0;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .article-body :global(th) {
    background: #1e293b;
    color: #f1f5f9;
    padding: 0.875rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
  }
  .article-body :global(td) {
    padding: 0.75rem 1rem;
    border-top: 1px solid #1e293b;
    color: #94a3b8;
  }
  .article-body :global(tr:hover td) {
    background: rgba(30, 41, 59, 0.5);
  }
</style>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    const update = () => {
      const doc = document.documentElement;
      const scrolled = doc.scrollTop || document.body.scrollTop;
      const total = doc.scrollHeight - doc.clientHeight;
      (bar as HTMLElement).style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
