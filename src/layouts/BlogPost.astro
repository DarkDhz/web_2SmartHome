---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  cat: string;
  date: string;
  time: string;
  img: string;
  imgAlt?: string;
  cta?: {
    eyebrow?: string;
    title?: string;
    text?: string;
    button?: string;
    href?: string;
  };
}

const {
  title,
  description,
  cat,
  date,
  time,
  img,
  imgAlt = title,
  cta = {},
} = Astro.props;

const finalCta = {
  eyebrow: '¿Listo para dar el salto?',
  title: 'Hablemos de tu proyecto',
  text: 'Visita gratuita y presupuesto sin compromiso. Nuestros expertos te asesoran sobre la mejor solución para tu hogar o empresa.',
  button: 'Solicitar asesoramiento gratuito',
  href: '/contacto',
  ...cta,
};
---

<Layout title={title} description={description} noIndex={false}>

  <!-- Reading progress bar -->
  <div class="fixed top-20 left-0 right-0 z-40 h-0.5 bg-slate-800">
    <div id="reading-progress" class="h-full bg-sky-500" style="width:0%;transition:none"></div>
  </div>

  <!-- Article hero -->
  <section class="bg-slate-900 border-b border-slate-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-slate-500 mb-10">
        <a href="/" class="hover:text-sky-400 transition-colors">Inicio</a>
        <svg class="w-3 h-3 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/recursos" class="hover:text-sky-400 transition-colors">Recursos</a>
        <svg class="w-3 h-3 text-slate-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-400 truncate">{title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-sky-500/20 text-sky-400 text-xs font-semibold rounded-lg border border-sky-500/30 uppercase tracking-wide">{cat}</span>
        <span class="text-slate-500 text-sm">{date}</span>
        <span class="text-slate-600">·</span>
        <span class="text-slate-500 text-sm flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {time} de lectura
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6">{title}</h1>
      <p class="text-lg sm:text-xl text-slate-300 leading-relaxed">{description}</p>
    </div>
  </section>

  <!-- Featured image -->
  <div class="bg-slate-950 pt-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-2xl border border-slate-800 h-64 sm:h-80 lg:h-[420px]">
        <img src={img} alt={imgAlt} class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  </div>

  <!-- Article body -->
  <div class="bg-slate-950 py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="article-body">
        <slot />
      </div>

      <!-- Bottom CTA -->
      <div class="mt-16 p-8 bg-slate-900 border border-sky-500/20 rounded-2xl text-center">
        <p class="text-sky-400 text-xs font-semibold uppercase tracking-wider mb-3">{finalCta.eyebrow}</p>
        <h3 class="text-2xl font-bold text-white mb-3">{finalCta.title}</h3>
        <p class="text-slate-400 mb-6 max-w-sm mx-auto text-sm leading-relaxed">{finalCta.text}</p>
        <a href={finalCta.href} class="inline-block px-8 py-4 bg-sky-500 hover:bg-sky-400 text-white font-semibold rounded-xl transition-all shadow-lg shadow-sky-500/25 hover:scale-105">
          {finalCta.button}
        </a>
      </div>
      <!-- Back to blog -->
      <div class="mt-10 text-center">
        <a href="/recursos" class="inline-flex items-center gap-2 text-sky-400 hover:text-sky-300 transition-colors font-medium text-sm">
          <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          Volver al blog de recursos
        </a>
      </div>
    </div>
  </div>

</Layout>

<style>
  .article-body :global(h2) {
    color: #f1f5f9;
    font-size: 1.625rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    padding-bottom: 0.625rem;
    border-bottom: 1px solid #1e293b;
  }
  .article-body :global(h3) {
    color: #e2e8f0;
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .article-body :global(p) {
    color: #94a3b8;
    font-size: 1.0625rem;
    line-height: 1.85;
    margin-bottom: 1.5rem;
  }
  .article-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
  }
  .article-body :global(ul li) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: #94a3b8;
    margin-bottom: 0.75rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .article-body :global(ul li::before) {
    content: "→";
    color: #38bdf8;
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-weight: 600;
  }
  .article-body :global(ol) {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.5rem;
    counter-reset: list-counter;
  }
  .article-body :global(ol li) {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    color: #94a3b8;
    margin-bottom: 0.875rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    counter-increment: list-counter;
  }
  .article-body :global(ol li::before) {
    content: counter(list-counter);
    background: #0ea5e9;
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    min-width: 1.625rem;
    height: 1.625rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .article-body :global(strong) {
    color: #e2e8f0;
    font-weight: 600;
  }
  .article-body :global(em) {
    color: #7dd3fc;
    font-style: italic;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid #0ea5e9;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
    background: rgba(14, 165, 233, 0.06);
    border-radius: 0 0.75rem 0.75rem 0;
  }
  .article-body :global(blockquote p) {
    color: #bae6fd;
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 0;
    font-style: italic;
  }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid #1e293b;
    margin: 2.5rem 0;
  }
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .article-body :global(th) {
    background: #1e293b;
    color: #f1f5f9;
    padding: 0.875rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.875rem;
  }
  .article-body :global(td) {
    padding: 0.75rem 1rem;
    border-top: 1px solid #1e293b;
    color: #94a3b8;
  }
  .article-body :global(tr:hover td) {
    background: rgba(30, 41, 59, 0.5);
  }
</style>

<script>
  const bar = document.getElementById('reading-progress');
  if (bar) {
    const update = () => {
      const doc = document.documentElement;
      const scrolled = doc.scrollTop || document.body.scrollTop;
      const total = doc.scrollHeight - doc.clientHeight;
      (bar as HTMLElement).style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    };
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
